# ── Required ──────────────────────────────────────────────────────────────────

# Your data source API key (replace with whatever powers your episode content)
# Example: Veynor prediction market data — free at veynor.xyz/agents
DATA_API_KEY=your_data_api_key_here

# Anthropic — script generation (claude.ai)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ElevenLabs — text-to-speech (elevenlabs.io)
ELEVENLABS_API_KEY=sk_your_key_here

# ElevenLabs voice ID
# Default: Brian (nPczCjzI2devNBz1zQrb) — American male, deep
# Other good options:
#   Daniel  onwK4e9ZLuTAKqWW03F9  — British broadcaster
#   Adam    pNInz6obpgDQGcFmaJgB  — American, authoritative
# To use your own cloned voice: create one at elevenlabs.io/app/voice-lab
# then paste the voice ID here
ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb

# ── Spotify (optional — only needed for auto-upload) ──────────────────────────
# Show ID from your Spotify for Creators URL
# e.g. creators.spotify.com/pod/show/YOUR_SHOW_ID/home
SPOTIFY_SHOW_ID=your_show_id_here
